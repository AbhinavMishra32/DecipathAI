// Decipath Prisma Schema
// Roadmap graph data is stored as a JSON document (nodes + edges + positions).
// Normalized per-node tables are intentionally avoided — the graph is the unit of persistence.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────────────────────
// Enums
// ───────────────────────────────────────────

enum Visibility {
  PRIVATE
  PUBLIC
}

enum ProgressStatus {
  ACTIVE
  COMPLETED
}

enum PlanTier {
  FREE
  PRO
}

enum BillingProvider {
  RAZORPAY
}

enum BillingPeriod {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  INCOMPLETE
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum UsageMetric {
  ROADMAP_GENERATION
}

enum GenerationStatus {
  STARTED
  SUCCEEDED
  FAILED
  REJECTED_QUOTA
}

// ───────────────────────────────────────────
// User — synced from Clerk via webhook
// ───────────────────────────────────────────

model User {
  id         String    @id @default(cuid())
  extId      String    @unique          // Clerk user id
  attributes Json
  username   String
  email      String
  planTier   PlanTier  @default(FREE)
  roadmaps   Roadmap[] @relation("OwnedRoadmaps")
  progressRuns RoadmapProgress[]
  roadmapLikes RoadmapLike[]
  roadmapComments RoadmapComment[]
  roadmapSaves RoadmapSave[]
  subscription UserSubscription?
  usageBuckets UsageBucket[]
  generationRuns RoadmapGenerationRun[]
}

// ───────────────────────────────────────────
// Roadmap — single-document graph storage
// ───────────────────────────────────────────

model Roadmap {
  id         String     @id @default(cuid())
  title      String
  slug       String                      // URL-safe slug derived from title
  visibility Visibility @default(PRIVATE)

  /// Full ReactFlow graph snapshot: { nodes: MindMapNode[], edges: MindMapEdge[] }
  graph      Json

  ownerId    String
  owner      User       @relation("OwnedRoadmaps", fields: [ownerId], references: [id])
  progressRuns RoadmapProgress[]
  likes      RoadmapLike[]
  comments   RoadmapComment[]
  saves      RoadmapSave[] @relation("RoadmapSourceSaves")
  savedCopies RoadmapSave[] @relation("RoadmapSavedCopy")

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([ownerId, updatedAt(sort: Desc)])
  @@index([slug])
}

model RoadmapLike {
  id         String   @id @default(cuid())
  roadmapId  String
  roadmap    Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, roadmapId])
  @@index([roadmapId, createdAt(sort: Desc)])
}

model RoadmapComment {
  id         String   @id @default(cuid())
  roadmapId  String
  roadmap    Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([roadmapId, createdAt(sort: Desc)])
}

model RoadmapSave {
  id               String    @id @default(cuid())
  sourceRoadmapId  String
  sourceRoadmap    Roadmap   @relation("RoadmapSourceSaves", fields: [sourceRoadmapId], references: [id], onDelete: Cascade)
  savedRoadmapId   String?
  savedRoadmap     Roadmap?  @relation("RoadmapSavedCopy", fields: [savedRoadmapId], references: [id], onDelete: SetNull)
  sourceCreatorName String
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())

  @@unique([userId, sourceRoadmapId])
  @@index([sourceRoadmapId, createdAt(sort: Desc)])
}

model RoadmapProgress {
  id               String          @id @default(cuid())
  status           ProgressStatus  @default(ACTIVE)
  currentNodeId    String?
  completedNodeIds String[]        @default([])
  completedAt      DateTime?

  roadmapId        String
  roadmap          Roadmap         @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskProgresses   RoadmapTaskProgress[]

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([userId, roadmapId])
  @@index([userId, updatedAt(sort: Desc)])
}

model RoadmapTaskProgress {
  id         String         @id @default(cuid())

  progressId String
  progress   RoadmapProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  nodeId     String
  taskIndex  Int
  completedAt DateTime      @default(now())

  @@unique([progressId, nodeId, taskIndex])
  @@index([progressId, nodeId])
}

model UserSubscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider               BillingProvider    @default(RAZORPAY)
  providerCustomerId     String?
  providerSubscriptionId String             @unique
  providerPlanId         String?
  status                 SubscriptionStatus @default(INCOMPLETE)
  billingPeriod          BillingPeriod?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  canceledAt             DateTime?
  metadata               Json?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@index([provider, status, currentPeriodEnd])
}

model BillingWebhookEvent {
  id               String          @id @default(cuid())
  provider         BillingProvider @default(RAZORPAY)
  providerEventId  String          @unique
  eventType        String
  payload          Json
  receivedAt       DateTime        @default(now())
  processedAt      DateTime?
  processingError  String?
}

model UsageBucket {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  metric      UsageMetric
  periodStart DateTime
  periodEnd   DateTime
  used        Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([userId, metric, periodStart])
  @@index([userId, metric, periodStart(sort: Desc)])
}

model RoadmapGenerationRun {
  id                       String           @id @default(cuid())
  userId                   String
  user                     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestId                String?
  status                   GenerationStatus @default(STARTED)
  planTierSnapshot         PlanTier
  periodStart              DateTime
  periodEnd                DateTime
  monthlyLimit             Int
  monthlyUsedBefore        Int
  monthlyUsedAfter         Int?
  maxSearchCalls           Int
  searchCallsUsed          Int              @default(0)
  maxSubqueriesPerCall     Int
  maxResultsPerQuery       Int
  maxSearchDepth           String
  pathwayPlanningMaxSteps  Int
  roadmapSynthesisMaxSteps Int
  currentStatePreview      String?
  desiredOutcomePreview    String?
  errorCode                String?
  errorMessage             String?
  startedAt                DateTime         @default(now())
  finishedAt               DateTime?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}
